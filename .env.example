# LLM provider configuration (for Gemini integration)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# Whisper / speech configuration
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu

# Indic translation backend
INDIC_TRANSLATION_BACKEND=indictrans

# Coqui TTS configuration
COQUI_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2

# YOLOv8 model path
YOLO_MODEL_PATH=models/yolov8n.pt
